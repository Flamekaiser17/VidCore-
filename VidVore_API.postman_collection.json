          }
        },
        {
          "name": "Toggle Tweet Like",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/likes/toggle/t/{{tweetId}}"
          }
