            "method": "POST",
            "url": "{{baseUrl}}/likes/toggle/v/{{videoId}}",
            "description": "Like or unlike a video (toggles)"
          }
        },
        {
          "name": "Toggle Comment Like",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
